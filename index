<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Leadership Lunch | Vurpix</title>
  <style>
    :root {
      --bg: #f5f7fa;
      --card: #ffffff;
      --text: #1f4f82;
      --text-soft: #6f8098;
      --border: #d9e3ee;
      --vurpix-blue: #1f6ba8;
      --vurpix-cyan: #1aa7d8;
      --accent: #e64868;
      --shadow: 0 10px 30px rgba(31, 79, 130, 0.10);
      --radius-xl: 28px;
      --radius-lg: 20px;
      --radius-md: 14px;
      --container: 1180px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    .container {
      width: min(var(--container), calc(100% - 32px));
      margin: 0 auto;
    }

    .topbar {
      position: sticky;
      top: 0;
      z-index: 50;
      padding: 16px 0;
      background: linear-gradient(to bottom, rgba(245,247,250,0.96), rgba(245,247,250,0.84));
      backdrop-filter: blur(8px);
    }

    .nav-shell {
      background: rgba(255,255,255,0.92);
      border: 1px solid #cfd9e5;
      border-radius: 999px;
      box-shadow: 0 3px 12px rgba(20, 54, 92, 0.08);
      padding: 10px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
    }

    .brand-row {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .brand-logo {
      height: 34px;
      width: auto;
      display: block;
    }

    .nav-cta,
    .hero-cta,
    .form button {
      background: var(--accent);
      color: white;
      border: 0;
      border-radius: 12px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.18s ease, box-shadow 0.18s ease, opacity 0.18s ease;
      box-shadow: 0 8px 18px rgba(230, 72, 104, 0.22);
    }

    .nav-cta:hover,
    .hero-cta:hover,
    .form button:hover {
      transform: translateY(-1px);
      opacity: 0.96;
    }

    .nav-cta {
      padding: 12px 18px;
      font-size: 1rem;
      white-space: nowrap;
    }

    .hero {
      min-height: calc(100vh - 90px);
      display: grid;
      place-items: center;
      text-align: center;
      padding: 36px 0 80px;
    }

    .hero-inner {
      max-width: 820px;
      margin: 0 auto;
    }

    .hero-logo {
      width: min(320px, 65vw);
      height: auto;
      display: block;
      margin: 0 auto 18px;
    }

    .partner-logo {
      width: min(165px, 42vw);
      display: block;
      margin: 0 auto 34px;
      border-radius: 8px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      border: 1px solid #c8d6e6;
      background: #edf3f8;
      color: var(--vurpix-blue);
      border-radius: 999px;
      padding: 10px 16px;
      font-size: 0.98rem;
      margin-bottom: 26px;
    }

    .pill-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--accent);
      display: inline-block;
      box-shadow: 0 0 0 4px rgba(230,72,104,0.10);
    }

    h1 {
      margin: 0;
      font-size: clamp(3rem, 7vw, 5.4rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
      font-weight: 800;
    }

    .title-line-1 {
      color: var(--vurpix-blue);
      display: block;
    }

    .title-line-2 {
      color: var(--vurpix-cyan);
      display: block;
    }

    .hero-copy {
      max-width: 760px;
      margin: 28px auto 30px;
      color: #667892;
      font-size: clamp(1.18rem, 2vw, 1.75rem);
      line-height: 1.45;
    }

    .event-meta {
      display: flex;
      justify-content: center;
      gap: 26px;
      flex-wrap: wrap;
      color: #6d7f97;
      font-size: 1rem;
      margin-bottom: 34px;
    }

    .meta-item {
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .meta-icon {
      color: var(--vurpix-cyan);
      font-size: 1rem;
    }

    .hero-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 230px;
      padding: 18px 28px;
      font-size: 1.18rem;
    }

    .section {
      padding: 70px 0 90px;
    }

    .section-heading {
      text-align: center;
      max-width: 760px;
      margin: 0 auto 36px;
    }

    .section-heading h2 {
      font-size: clamp(2.2rem, 4vw, 3.6rem);
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin: 0 0 12px;
      color: var(--vurpix-blue);
    }

    .section-heading p {
      margin: 0;
      color: #6d7f97;
      font-size: 1.2rem;
    }

    .form-wrap {
      max-width: 460px;
      margin: 0 auto;
      background: rgba(255,255,255,0.75);
      border: 1px solid #d7e2ed;
      box-shadow: var(--shadow);
      border-radius: var(--radius-lg);
      padding: 24px;
    }

    .form {
      display: grid;
      gap: 14px;
    }

    .field {
      display: grid;
      gap: 8px;
    }

    .field label {
      font-size: 0.98rem;
      font-weight: 700;
      color: var(--vurpix-blue);
    }

    .field input,
    .field select,
    .field textarea {
      width: 100%;
      border: 1px solid #cdd9e5;
      border-radius: 12px;
      background: #f8fbfd;
      padding: 16px 14px;
      font: inherit;
      color: #42546d;
      outline: none;
      transition: border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .field input:focus,
    .field select:focus,
    .field textarea:focus {
      border-color: #8fc5df;
      box-shadow: 0 0 0 4px rgba(26, 167, 216, 0.10);
    }

    .form button {
      width: 100%;
      padding: 16px 20px;
      font-size: 1.08rem;
      margin-top: 6px;
    }

    .form-note {
      text-align: center;
      color: #7a8aa1;
      font-size: 0.95rem;
      margin: 6px 0 0;
    }

    .footer {
      border-top: 1px solid #d9e2ec;
      padding: 36px 0 24px;
      text-align: center;
    }

    .footer-logos {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 22px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }

    .footer-logos img:first-child {
      height: 44px;
      width: auto;
    }

    .footer-logos img:last-child {
      height: 40px;
      width: auto;
      border-radius: 6px;
    }

    .footer-copy {
      color: #6f8098;
      font-size: 0.98rem;
    }

    .footer-copy span {
      margin: 0 8px;
      color: #a0adbe;
    }

    @media (max-width: 720px) {
      .topbar {
        padding: 12px 0;
      }

      .nav-shell {
        padding: 10px 14px;
      }

      .brand-logo {
        height: 28px;
      }

      .nav-cta {
        padding: 10px 14px;
        font-size: 0.95rem;
      }

      .hero {
        min-height: auto;
        padding-top: 38px;
      }

      .hero-copy {
        font-size: 1.08rem;
      }

      .event-meta {
        gap: 12px 18px;
        font-size: 0.95rem;
      }

      .footer-copy {
        line-height: 1.7;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="container">
      <div class="nav-shell">
        <div class="brand-row">
          <img class="brand-logo" src="assets/logo-vurpix.png" alt="Vurpix" />
        </div>
        <a class="nav-cta" href="#registro">Registrarme</a>
      </div>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-inner">
          <img class="hero-logo" src="assets/logo-vurpix.png" alt="Vurpix" />
          <img class="partner-logo" src="assets/salesforce-partner.png" alt="Salesforce Partner" />

          <div class="pill">
            <span class="pill-dot"></span>
            Evento exclusivo
          </div>

          <h1>
            <span class="title-line-1">AI Leadership</span>
            <span class="title-line-2">Lunch</span>
          </h1>

          <p class="hero-copy">
            Un almuerzo exclusivo para líderes que quieren descubrir cómo la IA puede transformar su negocio.
          </p>

          <div class="event-meta">
            <div class="meta-item"><span class="meta-icon">📅</span> 15 de Mayo, 2026</div>
            <div class="meta-item"><span class="meta-icon">📍</span> Buenos Aires, Argentina</div>
            <div class="meta-item"><span class="meta-icon">👥</span> Cupos limitados</div>
          </div>

          <a class="hero-cta" href="#registro">Reservar mi lugar</a>
        </div>
      </div>
    </section>

    <section class="section" id="registro">
      <div class="container">
        <div class="section-heading">
          <h2>Reserva tu lugar</h2>
          <p>Sin costo. Cupos limitados a 25 ejecutivos.</p>
        </div>

        <div class="form-wrap">
          <form class="form" action="https://formspree.io/f/TU_FORM_ID" method="POST">
            <div class="field">
              <label for="nombre">Nombre completo</label>
              <input id="nombre" name="nombre" type="text" placeholder="Tu nombre" required />
            </div>

            <div class="field">
              <label for="correo">Correo corporativo</label>
              <input id="correo" name="email" type="email" placeholder="tu@empresa.com" required />
            </div>

            <div class="field">
              <label for="empresa">Empresa</label>
              <input id="empresa" name="empresa" type="text" placeholder="Nombre de tu empresa" required />
            </div>

            <div class="field">
              <label for="cargo">Cargo</label>
              <input id="cargo" name="cargo" type="text" placeholder="Tu cargo actual" required />
            </div>

            <input type="hidden" name="_subject" value="Nuevo registro - AI Leadership Lunch" />
            <input type="hidden" name="_next" value="https://TU_USUARIO.github.io/TU_REPOSITORIO/gracias.html" />

            <button type="submit">Confirmar asistencia</button>
            <p class="form-note">Al registrarte aceptas recibir información sobre el evento.</p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-logos">
        <img src="assets/logo-vurpix.png" alt="Vurpix" />
        <img src="assets/salesforce-partner.png" alt="Salesforce Partner" />
      </div>
      <div class="footer-copy">
        Salesforce Consulting Partner <span>|</span> contacto@vurpix.com
      </div>
    </div>
  </footer>
</body>
</html>
